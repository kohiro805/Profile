---
import { PROFILE } from '../consts';
---

<section id="about" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="mb-12 text-center">
    <span class="text-sky-400 font-mono text-sm tracking-widest uppercase">// About</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mt-2">Parallel Career</h2>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Network Engineer Card -->
    <div class="group relative p-6 rounded-2xl border border-slate-700/50 bg-slate-900/60 backdrop-blur-md hover:border-sky-500/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(56,189,248,0.1)]">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-lg bg-sky-500/10 border border-sky-500/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
          </svg>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg">Network Engineer</h3>
          <span class="text-sky-400 font-mono text-xs">5+ Years</span>
        </div>
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">{PROFILE.bio.engineer}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {['Cisco', 'Juniper', 'BGP/OSPF', 'L3 Switch', 'Security'].map(tag => (
          <span class="px-2 py-1 text-xs font-mono bg-slate-800 border border-slate-700 text-sky-400 rounded">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Real Estate Investor Card -->
    <div class="group relative p-6 rounded-2xl border border-slate-700/50 bg-slate-900/60 backdrop-blur-md hover:border-sky-500/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(56,189,248,0.1)]">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-lg bg-sky-500/10 border border-sky-500/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg">Real Estate Investor</h3>
          <span class="text-sky-400 font-mono text-xs">HARUKAZE株式会社 代表</span>
        </div>
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">{PROFILE.bio.investor}</p>
      <div class="mt-4 p-3 rounded-lg bg-sky-500/5 border border-sky-500/20">
        <div class="flex items-center gap-2 text-xs font-mono">
          <span class="w-2 h-2 rounded-full bg-sky-400"></span>
          <span class="text-sky-400">物件 — {PROFILE.property}</span>
        </div>
      </div>
    </div>
  </div>
</section>
