---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-center gap-4 p-5 rounded-2xl border border-slate-700/50 bg-slate-900/60 backdrop-blur-md transition-all duration-300 hover:scale-[1.03] hover:border-slate-500/60 hover:shadow-[0_8px_30px_rgba(0,0,0,0.4)] hover:bg-slate-800/70"
  style={`--card-delay: ${delay}ms`}
>
  <!-- Icon -->
  <div
    class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
    style={`background-color: ${color}20; border: 1px solid ${color}40; color: ${color}`}
  >
    <div class="w-6 h-6" set:html={icons[icon]} />
  </div>

  <!-- Text -->
  <div class="flex-1 min-w-0">
    <p class="text-white font-semibold text-base group-hover:text-sky-400 transition-colors duration-200">{service}</p>
    <p class="text-slate-400 text-sm font-mono truncate">{label}</p>
  </div>

  <!-- Arrow -->
  <div class="flex-shrink-0 w-8 h-8 rounded-full border border-slate-700 flex items-center justify-center transition-all duration-300 group-hover:border-sky-500 group-hover:bg-sky-500/10">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 group-hover:text-sky-400 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
    </svg>
  </div>
</a>
