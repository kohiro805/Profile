---
import { AdminEditor } from '../components/AdminEditor';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Studio | Hiroto's Profile</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <AdminEditor client:load />

    <style is:global>
      :root {
        --c-primary: #2b7465;
        --c-secondary: #629b86;
        --font: 'Plus Jakarta Sans', 'Noto Sans JP', sans-serif;
      }

      body {
        margin: 0;
        font-family: var(--font);
        background: radial-gradient(circle at center, #1e3a34, #0a0f0d);
        color: white;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .admin-login, .admin-dashboard {
        width: 100%;
        max-width: 800px;
        padding: 20px;
      }

      .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
      }

      .glass-panel.wide { max-width: 900px; }

      h1 { font-size: 28px; margin-bottom: 30px; letter-spacing: -0.02em; }
      h3 { font-size: 16px; opacity: 0.6; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 0.1em; }

      .admin-login form {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      input[type="password"], input[type="text"], textarea {
        width: 100%;
        padding: 16px 20px;
        background: rgba(0,0,0,0.2);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        color: white;
        font-size: 16px;
        font-family: inherit;
      }

      button {
        padding: 16px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
      }

      button.primary { background: #fff; color: #000; }
      button.primary:hover { transform: scale(1.02); background: #eee; }
      button.secondary { background: rgba(255,255,255,0.1); color: #fff; }
      button.danger { background: rgba(255, 82, 82, 0.2); color: #ff5252; }

      .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
      }
      .actions { display: flex; gap: 12px; }

      .editor-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
      }
      @media (min-width: 768px) {
        .editor-grid { grid-template-columns: 1fr 1fr; }
      }

      .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
      .field label { font-size: 13px; font-weight: 700; opacity: 0.8; }

      .color-picker-row {
        display: flex;
        gap: 10px;
        align-items: center;
      }
      input[type="color"] {
        width: 60px; height: 50px; padding: 0; border: none; background: none; cursor: pointer;
      }

      .preview-swatch {
        height: 100px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        background: #000;
        margin-top: 20px;
        box-shadow: inset 0 0 40px rgba(0,0,0,0.2);
      }

      .footer-actions {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .back-link { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 600; }
      .back-link:hover { color: #fff; }
    </style>
  </body>
</html>
